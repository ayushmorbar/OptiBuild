# Copy to app/.env and fill in. app/.env is git-ignored.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_ai_studio_key_here

# --- Cost-control flags (safe defaults: leave as-is) ---
# Eval suite is DISABLED by default (admin-only; spends real LLM credits).
# Set to 1 ONLY when intentionally running scripts/run_eval.py.
GAUSS_EVAL_ENABLED=0
# One-shot modelization (~5x fewer LLM calls). 0 = full staged loop (default).
GAUSS_FAST_MODELIZATION=0
